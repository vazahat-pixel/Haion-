# Local dev: use /api with Vite dev proxy (recommended) or http://localhost:3000/api direct
VITE_API_BASE_URL=/api
VITE_APP_NAME=Haion ERP
VITE_APP_VERSION=1.0.0
# Dev only: true = mock data, false = real API (backend must be running on :3000)
VITE_USE_MOCK_API=false

# ── Vercel deployment (set in Vercel dashboard, NOT in .env files) ──
#
# FRONTEND project (Root Directory = frontend):
#   BACKEND_URL=https://your-backend-project.vercel.app
#   VITE_RAZORPAY_KEY_ID=rzp_live_xxx  (optional)
#
# BACKEND project (Root Directory = backend):
#   MONGODB_URI=...
#   JWT_ACCESS_SECRET=... (min 32 chars)
#   JWT_REFRESH_SECRET=... (min 32 chars)
#   CORS_ORIGIN=https://your-frontend-project.vercel.app
#   NODE_ENV=production
#
# After changing env vars in Vercel, trigger a new deployment (Redeploy).
